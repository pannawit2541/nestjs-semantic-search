{
  "name": "nestjs-semantic-search",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "db:up": "docker compose up -d postgres adminer",
    "db:down": "docker compose down",
    "api:migration:generate": "pnpm --filter @semantic-search/api migration:generate",
    "api:migration:run": "pnpm --filter @semantic-search/api migration:run",
    "api:migration:revert": "pnpm --filter @semantic-search/api migration:revert"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "turbo": "^2.5.8",
    "typescript": "^5.7.2"
  }
}
